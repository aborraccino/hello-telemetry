# =============================================================
# Port Configuration
# Change host-side ports here if any conflict with your system.
# =============================================================

# --- MySQL ---
MYSQL_PORT=3306

# --- Tomcat (Java Web App) ---
TOMCAT_PORT=8085
JMX_PORT=9010
JMX_RMI_PORT=1099

# --- Python Service ---
# Mac users: port 5000 conflicts with AirPlay Receiver on macOS Monterey+.
# To fix, change this to 5001 (or any free port).
PYTHON_PORT=5001

# --- OTel Collector ---
OTEL_PPROF_PORT=1888
OTEL_PROMETHEUS_PORT=8888
OTEL_PROMETHEUS_EXPORTER_PORT=8889
OTEL_HEALTH_PORT=13133
OTLP_GRPC_PORT=4317
OTLP_HTTP_PORT=4318
OTEL_ZPAGES_PORT=55679

# --- Jaeger ---
JAEGER_UI_PORT=16686
